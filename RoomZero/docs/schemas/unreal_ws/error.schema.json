{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RoomZero Unreal Error",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "error"
    },
    "protocol_version": {
      "type": "string",
      "const": "roomzero.unreal.v1"
    },
    "error": {
      "type": "string",
      "enum": [
        "unknown_message_type",
        "missing_event",
        "invalid_payload"
      ]
    }
  },
  "required": [
    "type",
    "protocol_version",
    "error"
  ],
  "additionalProperties": true
}
