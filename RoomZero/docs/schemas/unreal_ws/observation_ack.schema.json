{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RoomZero Unreal Observation Ack",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "ack"
    },
    "protocol_version": {
      "type": "string",
      "const": "roomzero.unreal.v1"
    },
    "kind": {
      "type": "string",
      "const": "observation"
    },
    "agent_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "type",
    "protocol_version",
    "kind",
    "agent_id",
    "created_at"
  ],
  "additionalProperties": true
}
